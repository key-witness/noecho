{
  "name": "noecho",
  "version": "0.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "noecho",
      "version": "0.0.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "dependencies": {
        "zod": "^4.4.1"
      },
      "engines": {
        "node": ">=24"
      }
    },
    "apps/daemon": {
      "name": "@noecho/daemon",
      "version": "0.0.0",
      "bin": {
        "noecho": "src/cli.mjs"
      }
    },
    "apps/server": {
      "name": "@noecho/server",
      "version": "0.0.0"
    },
    "apps/web": {
      "name": "@noecho/web",
      "version": "0.0.0"
    },
    "node_modules/@noecho/agents": {
      "resolved": "packages/agents",
      "link": true
    },
    "node_modules/@noecho/daemon": {
      "resolved": "apps/daemon",
      "link": true
    },
    "node_modules/@noecho/db": {
      "resolved": "packages/db",
      "link": true
    },
    "node_modules/@noecho/prompts": {
      "resolved": "packages/prompts",
      "link": true
    },
    "node_modules/@noecho/protocol": {
      "resolved": "packages/protocol",
      "link": true
    },
    "node_modules/@noecho/server": {
      "resolved": "apps/server",
      "link": true
    },
    "node_modules/@noecho/web": {
      "resolved": "apps/web",
      "link": true
    },
    "node_modules/zod": {
      "version": "4.4.1",
      "resolved": "https://registry.npmjs.org/zod/-/zod-4.4.1.tgz",
      "integrity": "sha512-a6ENMBBGZBsnlSebQ/eKCguSBeGKSf4O7BPnqVPmYGtpBYI7VSqoVqw+QcB7kPRjbqPwhYTpFbVj/RqNz/CT0Q==",
      "license": "MIT",
      "funding": {
        "url": "https://github.com/sponsors/colinhacks"
      }
    },
    "packages/agents": {
      "name": "@noecho/agents",
      "version": "0.0.0"
    },
    "packages/db": {
      "name": "@noecho/db",
      "version": "0.0.0"
    },
    "packages/prompts": {
      "name": "@noecho/prompts",
      "version": "0.0.0"
    },
    "packages/protocol": {
      "name": "@noecho/protocol",
      "version": "0.0.0"
    }
  }
}
